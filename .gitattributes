* text=auto

# Keep source and configuration files normalized as UTF-8 with LF endings.
*.cjs text eol=lf
*.css text eol=lf
*.html text eol=lf
*.js text eol=lf
*.json text eol=lf
*.jsx text eol=lf
*.md text eol=lf
*.mjs text eol=lf
*.svg text eol=lf
*.ts text eol=lf
*.tsx text eol=lf

# Never apply text conversion to binary assets.
*.gif binary
*.ico binary
*.jpeg binary
*.jpg binary
*.png binary
*.webp binary
*.woff binary
*.woff2 binary
